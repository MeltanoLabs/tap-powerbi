# Power BI Configuration
# Copy this file to .env and fill in your actual values.

# Service-principal auth (recommended for unattended runs)
TAP_POWERBI_TENANT_ID=00000000-0000-0000-0000-000000000000
TAP_POWERBI_CLIENT_ID=00000000-0000-0000-0000-000000000000
TAP_POWERBI_CLIENT_SECRET=your-client-secret

# Delegated-user auth (use instead of TAP_POWERBI_TENANT_ID)
# TAP_POWERBI_REFRESH_TOKEN=your-refresh-token

# Optional: restrict discovery to specific workspaces (JSON array)
# TAP_POWERBI_WORKSPACE_IDS='["00000000-0000-0000-0000-000000000000"]'

# Optional: earliest timestamp for incremental streams
TAP_POWERBI_START_DATE=2024-01-01T00:00:00Z

# Optional: override for sovereign clouds
# TAP_POWERBI_API_URL=https://api.powerbi.com/v1.0/myorg

# Optional: enable /admin/* routes (requires Tenant.Read.All)
# TAP_POWERBI_ADMIN_MODE=false
